# Server Config
PORT=8080
ENV=development
API_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rawly_db
DB_SSLMODE=disable

# JWT Settings
JWT_SECRET=rawly_secret_key_change_me_in_production_1234567890
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Upload Constraints
MAX_AVATAR_SIZE_MB=5
MAX_MEDIA_SIZE_MB=50

# Rate Limiter
RATE_LIMIT_MAX=100
RATE_LIMIT_DURATION_SECONDS=60
